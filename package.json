{
  "name": "awesome-coolify-mcp",
  "version": "0.2.0",
  "description": "MCP server for Coolify 4.1.x — deploy, diagnose, and CRUD for keys, servers, projects, and environments via action-based tools",
  "type": "module",
  "bin": {
    "awesome-coolify-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node scripts/run-mcp.mjs",
    "mcp": "node scripts/run-mcp.mjs",
    "kill-mcp": "node scripts/kill-mcp.mjs",
    "lint": "tsup",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build",
    "higgsfield:fix": "bash scripts/fix-higgsfield.sh",
    "gsd:fix-verification": "node scripts/gsd-ensure-verification-fresh.mjs",
    "prepare": "husky",
    "version": "changeset version",
    "publint": "publint",
    "uat:live": "node scripts/live-uat.mjs"
  },
  "files": [
    "dist",
    ".env.example",
    "LICENSE"
  ],
  "keywords": [
    "coolify",
    "mcp",
    "model-context-protocol",
    "ai",
    "self-hosted",
    "devops",
    "deploy",
    "cursor",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clezcoding/awesome-coolify.git"
  },
  "bugs": {
    "url": "https://github.com/clezcoding/awesome-coolify/issues"
  },
  "homepage": "https://github.com/clezcoding/awesome-coolify#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "^2.0.0-beta.4",
    "ofetch": "^1.5.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "publint": "^0.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.15.1"
}
