{
  "name": "awesome-coolify-mcp",
  "version": "0.1.0",
  "description": "MCP server for Coolify — deploy, logs, diagnose via action-based tools",
  "type": "module",
  "bin": {
    "awesome-coolify-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node scripts/run-mcp.mjs",
    "mcp": "node scripts/run-mcp.mjs",
    "kill-mcp": "node scripts/kill-mcp.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "higgsfield:fix": "bash scripts/fix-higgsfield.sh",
    "gsd:fix-verification": "node scripts/gsd-ensure-verification-fresh.mjs"
  },
  "files": [
    "dist",
    ".env.example",
    "LICENSE"
  ],
  "keywords": [
    "coolify",
    "mcp",
    "model-context-protocol",
    "ai",
    "self-hosted",
    "devops",
    "deploy",
    "cursor",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clezcoding/awesome-coolify-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/clezcoding/awesome-coolify-mcp/issues"
  },
  "homepage": "https://github.com/clezcoding/awesome-coolify-mcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "^2.0.0-beta.3",
    "ofetch": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.4.0"
  }
}
