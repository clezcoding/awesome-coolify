{
  "runtime": "cursor",
  "model_profile": "inherit",
  "models": {
    "planning": "inherit",
    "research": "inherit",
    "execution": "inherit",
    "verification": "inherit"
  },
  "model_overrides": {
    "gsd-planner": "glm-5.2-high",
    "gsd-roadmapper": "glm-5.2-high",
    "gsd-executor": "composer-2.5-fast",
    "gsd-debugger": "claude-sonnet-5-thinking-high",
    "gsd-verifier": "glm-5.2-high",
    "gsd-plan-checker": "composer-2.5-fast",
    "gsd-project-researcher": "gemini-3.5-flash",
    "gsd-phase-researcher": "gemini-3.5-flash",
    "gsd-research-synthesizer": "gemini-3.5-flash",
    "gsd-codebase-mapper": "gemini-3.5-flash",
    "gsd-pattern-mapper": "gemini-3.5-flash",
    "gsd-nyquist-auditor": "gemini-3.5-flash",
    "gsd-integration-checker": "gemini-3.5-flash",
    "gsd-doc-writer": "composer-2.5-fast",
    "gsd-doc-verifier": "gemini-3.5-flash",
    "gsd-security-auditor": "glm-5.2-high"
  },
  "commit_docs": true,
  "parallelization": true,
  "search_gitignored": true,
  "brave_search": true,
  "firecrawl": false,
  "exa_search": true,
  "git": {
    "branching_strategy": "phase",
    "create_tag": true,
    "base_branch": "main",
    "phase_branch_template": "gsd/phase-{phase}-{slug}",
    "milestone_branch_template": "gsd/{milestone}-{slug}",
    "quick_branch_template": "gsd/quick-{quick}-{slug}"
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "auto_advance": false,
    "use_worktrees": false,
    "node_repair": true,
    "node_repair_budget": 2,
    "ui_phase": true,
    "ui_safety_gate": true,
    "ai_integration_phase": true,
    "human_verify_mode": "end-of-phase",
    "context_guard_mode": "warn",
    "text_mode": false,
    "research_before_questions": false,
    "discuss_mode": "discuss",
    "skip_discuss": false,
    "code_review": true,
    "code_review_depth": "standard",
    "code_review_command": null,
    "pattern_mapper": true,
    "plan_bounce": false,
    "plan_bounce_script": null,
    "plan_bounce_passes": 2,
    "auto_prune_state": false,
    "post_planning_gaps": true,
    "security_enforcement": true,
    "security_asvs_level": 1,
    "security_block_on": "high",
    "_auto_chain_active": false
  },
  "ship": {
    "pr_body_sections": [
      {
        "heading": "User Stories & Acceptance Criteria",
        "enabled": true,
        "source": "REQUIREMENTS.md ## User Stories || REQUIREMENTS.md ## Acceptance Criteria",
        "fallback": "- Acceptance criteria are covered by the linked requirements and verification evidence."
      },
      {
        "heading": "Risks & Dependencies",
        "enabled": true,
        "source": "PLAN.md ## Risks || PLAN.md ## Dependencies",
        "fallback": "- No known high-risk rollout dependencies."
      },
      {
        "heading": "Success Metrics & Release Criteria",
        "enabled": true,
        "source": "REQUIREMENTS.md ## Definition of Done || VERIFICATION.md ## Release Criteria",
        "fallback": "- Release when automated verification and required manual checks pass."
      },
      {
        "heading": "Stakeholder Review & Approval",
        "enabled": true,
        "template": "- Product owner approval pending for {phase_name}."
      }
    ]
  },
  "hooks": {
    "context_warnings": true
  },
  "project_code": null,
  "phase_naming": "sequential",
  "agent_skills": {},
  "claude_md_path": "./.cursor/rules/",
  "plan_review": {
    "source_grounding": true,
    "source_grounding_authority": "grep"
  },
  "resolve_model_ids": "omit",
  "mode": "yolo",
  "granularity": "standard",
  "response_language": "de"
}
